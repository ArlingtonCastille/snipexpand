{
  "manifest_version": 3,
  "name": "SnipExpand",
  "version": "1.0.0",
  "description": "Type a short trigger, get a long snippet. Local-first text expansion with no account required.",
  "permissions": ["storage", "clipboardRead"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SnipExpand"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
